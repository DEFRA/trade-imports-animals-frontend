{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/file-upload/macro.njk" import govukFileUpload %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "standalone/live-animals/shared/save-actions.njk" import saveActions %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <form method="post" enctype="multipart/form-data" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukSelect({
      id: "accompanyingDocumentType",
      name: "accompanyingDocumentType",
      label: { text: "Document type", classes: "govuk-label--s" },
      value: values.accompanyingDocumentType,
      errorMessage: errors.accompanyingDocumentType and { text: errors.accompanyingDocumentType },
      items: typeItems
    }) }}

    {{ govukInput({
      id: "accompanyingDocumentReference",
      name: "accompanyingDocumentReference",
      label: { text: "Document reference", classes: "govuk-label--s" },
      hint: { text: "For example, GBHC1234567890." },
      classes: "govuk-input--width-20",
      value: values.accompanyingDocumentReference,
      errorMessage: errors.accompanyingDocumentReference and { text: errors.accompanyingDocumentReference }
    }) }}

    {{ govukDateInput(dateOfIssue) }}

    {%- set fileHintHtml -%}
      <p class="govuk-!-font-weight-bold govuk-!-margin-bottom-1">Your file must be:</p>
      <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
        <li>smaller than {{ maxFileSizeLabel }}</li>
        <li>a {{ allowedFileTypesHint }}</li>
      </ul>
    {%- endset -%}

    {{ govukFileUpload({
      id: "file",
      name: "file",
      label: { text: "Upload a file", classes: "govuk-label--s" },
      hint: { html: fileHintHtml },
      attributes: { accept: acceptAttribute },
      errorMessage: errors.file and { text: errors.file }
    }) }}

    {{ govukButton({
      text: "Save and add another",
      classes: "govuk-button--secondary",
      name: "action",
      value: "add"
    }) }}

    {% if hasDocuments %}
      <div id="documents-added">
        {{ govukTable({
          caption: "Documents you have added",
          captionClasses: "govuk-visually-hidden",
          head: [
            { text: "Document reference" },
            { text: "Document type" },
            { text: "Date of issue" },
            { text: "Status" },
            { html: '<span class="govuk-visually-hidden">Actions</span>' }
          ],
          rows: rows
        }) }}
      </div>
      {% if anyPending %}
        <p class="govuk-body">
          <a href="{{ refreshHref }}" class="govuk-link">Refresh virus scan status</a>
        </p>
      {% endif %}
      {% if timedOut %}
        <p class="govuk-hint">Still checking some documents. Refresh again in a moment.</p>
      {% endif %}
    {% else %}
      <p class="govuk-body">{{ emptyText }}</p>
    {% endif %}

    {{ saveActions(hubHref, { text: "Continue", name: "action", value: "continue" }) }}
  </form>
{% endblock %}

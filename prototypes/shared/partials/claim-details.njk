{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}

<p class="govuk-body">
  You told us you have had a claim in the last 5 years, so we need a few details.
</p>

{{ govukRadios({
  name: "claimType",
  fieldset: {
    legend: {
      text: "What type of claim was it?",
      classes: "govuk-fieldset__legend--m"
    }
  },
  items: items
}) }}

{{ govukInput({
  label: { text: "Approximate claim amount" },
  id: "claimAmount",
  name: "claimAmount",
  classes: "govuk-input--width-5",
  prefix: { text: "£" },
  inputmode: "numeric",
  value: quote.claimAmount
}) }}

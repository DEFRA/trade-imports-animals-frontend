{% extends "input-types/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block journeyContent %}
  {{ govukErrorSummary({
    titleText: "There is a problem",
    errorList: errorList
  }) }}

  <h1 class="govuk-heading-l">Validation and error states</h1>

  <p class="govuk-body">
    A worked example of how GDS shows errors — an error summary at the top,
    linked to each field, with a red message beside the input. These are static
    for illustration.
  </p>

  {% include "shared/partials/fields.njk" %}

  {{ govukButton({ text: "Continue", href: continueHref }) }}
{% endblock %}

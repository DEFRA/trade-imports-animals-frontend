{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "standalone/live-animals/features/commodities/_identification-card.njk" import identificationCard %}
{% from "standalone/live-animals/shared/save-actions.njk" import saveActions %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  {{ govukInsetText({
    text: "You must add all animal identification details before the consignment arrives at the port of entry."
  }) }}

  {% if hasLines %}
    <form method="post" novalidate>
      <input type="hidden" name="crumb" value="{{ crumb }}" />

      {% for card in cards %}
        {{ identificationCard(card) }}
      {% endfor %}

      {{ saveActions(hubHref, { text: "Save and finish", name: "action", value: "finish" }) }}
    </form>
  {% else %}
    <p class="govuk-body">{{ emptyText }}</p>
    <p class="govuk-body">
      <a class="govuk-link" href="{{ addHref }}">Add a commodity</a>
    </p>
  {% endif %}
{% endblock %}

{# Commodity-lines index page — bespoke because the flow layer doesn't
   yet model an Add-another primitive. Lists existing lines with a
   Change link and offers an Add-another button. #}

{% extends "layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block journeyContent %}
  <h1 class="govuk-heading-l">{{ heading }}</h1>

  {% if lead %}<p class="govuk-body">{{ lead }}</p>{% endif %}

  {% if lines and lines.length %}
    {{ govukSummaryList({ rows: lines }) }}
  {% else %}
    <p class="govuk-body">No commodity lines added yet.</p>
  {% endif %}

  <form method="post" action="{{ addHref }}" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />
    {{ govukButton({ text: "Add a commodity line", classes: "govuk-button--secondary" }) }}
  </form>

  {% if backLink %}
    <p class="govuk-body">
      <a class="govuk-link" href="{{ backLink }}">Back to task list</a>
    </p>
  {% endif %}
{% endblock %}

{% extends "live-animals/shared/layout.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "live-animals/shared/save-actions.njk" import saveActions %}

{% block journeyContent %}
  {% include "live-animals/shared/error-summary.njk" %}

  <p class="govuk-body">{{ copy.guidance.authorisationLead }}</p>
  <ul class="govuk-list govuk-list--bullet govuk-list--spaced">
    {% for condition in copy.guidance.authorisationConditions %}
      <li>{{ condition }}</li>
    {% endfor %}
  </ul>
  <p class="govuk-body">
    <a href="{{ copy.guidance.linkHref }}" class="govuk-link" rel="noreferrer noopener" target="_blank">{{ copy.guidance.linkText }}</a>
  </p>
  <p class="govuk-body">{{ copy.guidance.daeraValid }}</p>
  <p class="govuk-body">{{ copy.guidance.euNotValid }}</p>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukRadios({
      name: "transporterType",
      fieldset: {
        legend: {
          text: copy.legend,
          isPageHeading: true,
          classes: "govuk-fieldset__legend--l"
        }
      },
      hint: { text: copy.hint },
      errorMessage: errors.transporterType and { text: errors.transporterType },
      items: [
        {
          value: "Commercial",
          text: copy.options["Commercial"].text,
          hint: { text: copy.options["Commercial"].hint },
          checked: values.transporterType == "Commercial"
        },
        {
          value: "Private",
          text: copy.options["Private"].text,
          hint: { text: copy.options["Private"].hint },
          checked: values.transporterType == "Private"
        }
      ]
    }) }}

    {{ saveActions(hubHref, copy = sharedCopy.saveActions) }}
  </form>
{% endblock %}

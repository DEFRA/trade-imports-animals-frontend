{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}


{% block content %}
  {{ appReferenceNumberCaption({ referenceNumber: referenceNumber }) }}

  {{ govukBackLink({
    text: "Back",
    href: "/import-reason"
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="app-page-body">

        {% if errorList %}
          {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: errorList
          }) }}
        {% endif %}

        <form method="post" id="commodity-details-form" name="commodity-details-form" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        <input type="hidden" id="totalNoOfAnimals" name="totalNoOfAnimals" value="{{ totalNoOfAnimals }}" />
        <input type="hidden" id="totalNoOfPackages" name="totalNoOfPackages" value="{{ totalNoOfPackages }}" />

          {{ appHeading({ caption: "Description of the goods", text: "Commodity" }) }}

          <table class="govuk-table">
            <caption class="govuk-table__caption govuk-table__caption--m">Commodities</caption>
            <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Commodity code</th>
              <th scope="col" class="govuk-table__header govuk-!-width-two-thirds">Description</th>
            </tr>
            </thead>
            <tbody class="govuk-table__body">
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">0102</td>
                <td class="govuk-table__cell">Live bovine animals</td>
              </tr>
            </tbody>
          </table>

          <table class="govuk-table">
            <caption class="govuk-table__caption govuk-table__caption--m">Live bovine animals</caption>
            <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Species and type</th>
              <th scope="col" class="govuk-table__header">Number of animals</th>
              <th scope="col" class="govuk-table__header">Number of packages such as crates, bags or boxes (when required)</th>
            </tr>
            </thead>
            <tbody class="govuk-table__body">
            {% for species in speciesLst %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">
                  {{ species.text }}, {{ typeOfCommodity }}
                </td>
                <td class="govuk-table__cell">
                  {{ govukInput({
                    id: "noOfAnimals-" + species.value,
                    name: "noOfAnimals-" + species.value,
                    value: species.noOfAnimals,
                    type: "number",
                    label: {
                      text: "Number of animals for " + species.text,
                      classes: "govuk-visually-hidden"
                    }
                  }) }}
                </td>
                <td class="govuk-table__cell">
                  {{ govukInput({
                    id: "noOfPackages-" + species.value,
                    name: "noOfPackages-" + species.value,
                    value: species.noOfPackages,
                    type: "number",
                    label: {
                      text: "Number of packages for " + species.text,
                      classes: "govuk-visually-hidden"
                    }
                  }) }}
                </td>
              </tr>
            {% endfor %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-table__header">Subtotal</td>
                <td class="govuk-table__cell" id="subtotalNoOfAnimals">{{ totalNoOfAnimals }}</td>
                <td class="govuk-table__cell" id="subtotalNoOfPackages">{{ totalNoOfPackages }}</td>
              </tr>
            </tbody>
          </table>

          <div class="govuk-button-group">
            {{ govukButton({
              text: "Save and continue"
            }) }}
          </div>

        </form>

      </div>
    </div>
  </div>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('commoditySubTotal.js') }}"></script>
{% endblock %}


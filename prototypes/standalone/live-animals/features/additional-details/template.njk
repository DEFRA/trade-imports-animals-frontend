{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "standalone/live-animals/shared/save-actions.njk" import saveActions %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">Additional animal details</h1>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukRadios({
      name: "animalsCertifiedFor",
      fieldset: {
        legend: {
          text: "What are the animals certified for?",
          classes: "govuk-fieldset__legend--s"
        }
      },
      hint: { text: "You'll find this on the health certificate." },
      errorMessage: errors.animalsCertifiedFor and { text: errors.animalsCertifiedFor },
      items: certifiedOptions
    }) }}

    {% if showUnweaned %}
      {{ govukRadios({
        name: "containsUnweanedAnimals",
        fieldset: {
          legend: {
            text: "Does the consignment contain any unweaned animals?",
            classes: "govuk-fieldset__legend--s"
          }
        },
        hint: { text: "These are animals that are still feeding from their mother." },
        errorMessage: errors.containsUnweanedAnimals and { text: errors.containsUnweanedAnimals },
        items: unweanedOptions
      }) }}
    {% endif %}

    {{ saveActions(hubHref) }}
  </form>
{% endblock %}

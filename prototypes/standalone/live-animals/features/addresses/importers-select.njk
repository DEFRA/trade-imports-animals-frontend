{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukRadios({
      name: "importer",
      fieldset: {
        legend: {
          html: '<span class="govuk-caption-l">Consignment addresses</span> Importer',
          isPageHeading: true,
          classes: "govuk-fieldset__legend--l"
        }
      },
      hint: { text: "Selecting an importer copies its name and address into this notification." },
      errorMessage: errors.importer and { text: errors.importer },
      items: importerOptions
    }) }}

    <div class="govuk-button-group">
      {{ govukButton({ text: "Save and continue" }) }}
      {{ govukButton({ text: "Add a new address", classes: "govuk-button--secondary", href: createAddressHref }) }}
    </div>
  </form>
{% endblock %}

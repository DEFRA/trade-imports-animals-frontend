{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
  {{ appReferenceNumberCaption({ referenceNumber: referenceNumber }) }}

  {{ govukBackLink({
    text: "Back",
    href: "/accompanying-documents"
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="app-page-body">

        {% if errorList %}
          {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: errorList
          }) }}
        {% endif %}

        {{ appHeading({ caption: heading, text: heading }) }}

        <form method="post" novalidate>
          <input type="hidden" name="crumb" value="{{ crumb }}" />

          <div class="govuk-form-group">
            <fieldset class="govuk-fieldset">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                <h2 class="govuk-fieldset__heading">Consignor or exporter</h2>
              </legend>
              <div id="consignor-hint" class="govuk-hint">
                This is the sender of the consignment.
              </div>
              {% if selectedConsignor %}
                <table class="govuk-table govuk-table--small-text-until-tablet">
                  <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                      <th scope="col" class="govuk-table__header">Name</th>
                      <th scope="col" class="govuk-table__header">Address</th>
                      <th scope="col" class="govuk-table__header">Country</th>
                    </tr>
                  </thead>
                  <tbody class="govuk-table__body">
                    <tr class="govuk-table__row">
                      <td class="govuk-table__cell">{{ selectedConsignor.name }}</td>
                      <td class="govuk-table__cell">
                        {{ selectedConsignor.address.addressLine1 }}{% if selectedConsignor.address.addressLine2 %}, {{ selectedConsignor.address.addressLine2 }}{% endif %}{% if selectedConsignor.address.addressLine3 %}, {{ selectedConsignor.address.addressLine3 }}{% endif %}
                      </td>
                      <td class="govuk-table__cell">{{ selectedConsignor.address.country }}</td>
                    </tr>
                  </tbody>
                </table>
              {% else %}
                <p class="govuk-body">
                  <a href="/consignors/select" class="govuk-link govuk-link--no-visited-state" id="addConsignorOrExporter" aria-describedby="consignor-hint">Add a consignor or exporter</a>
                </p>
              {% endif %}
            </fieldset>
          </div>
          <div class="govuk-form-group">
            <fieldset class="govuk-fieldset">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                <h2 class="govuk-fieldset__heading">Place of destination</h2>
              </legend>
              <div id="place-of-destination-hint" class="govuk-hint">
                This is where the animals will be unloaded and accommodated for at least 48 hours. If a health certificate is required, it will show this address.
              </div>
              <div class="govuk-warning-text">
                <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                <strong class="govuk-warning-text__text">
                  <span class="govuk-visually-hidden">Warning</span>
                  Providing a false address is an act of fraud.
                </strong>
              </div>
              {% if selectedDestination %}
                <table class="govuk-table govuk-table--small-text-until-tablet">
                  <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                      <th scope="col" class="govuk-table__header">Name</th>
                      <th scope="col" class="govuk-table__header">Address</th>
                      <th scope="col" class="govuk-table__header">Country</th>
                    </tr>
                  </thead>
                  <tbody class="govuk-table__body">
                    <tr class="govuk-table__row">
                      <td class="govuk-table__cell">{{ selectedDestination.name }}</td>
                      <td class="govuk-table__cell">
                        {{ selectedDestination.address.addressLine1 }}{% if selectedDestination.address.addressLine2 %}, {{ selectedDestination.address.addressLine2 }}{% endif %}{% if selectedDestination.address.addressLine3 %}, {{ selectedDestination.address.addressLine3 }}{% endif %}
                      </td>
                      <td class="govuk-table__cell">{{ selectedDestination.address.country }}</td>
                    </tr>
                  </tbody>
                </table>
              {% else %}
                <p class="govuk-body">
                  <a href="/destinations/select" class="govuk-link govuk-link--no-visited-state" id="addPlaceOfDestination" aria-describedby="place-of-destination-hint">Add a place of destination</a>
                </p>
              {% endif %}
            </fieldset>
          </div>

          {{ govukButton({ text: "Save and continue" }) }}

        </form>
      </div>
    </div>
  </div>
{% endblock %}

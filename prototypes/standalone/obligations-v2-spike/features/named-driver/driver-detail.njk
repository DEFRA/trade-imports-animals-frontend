{% extends "standalone/obligations-v2-spike/shared/layout.njk" %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block journeyContent %}
  <h1 class="govuk-heading-l">{{ heading }}</h1>

  {{ govukSummaryList({ rows: detailRows }) }}

  <h2 class="govuk-heading-m">Claims for this driver</h2>

  {% if hasClaims %}
    {{ govukSummaryList({ rows: claimRows }) }}
  {% else %}
    <p class="govuk-body">{{ emptyClaimsText }}</p>
  {% endif %}

  {{ govukButton({
    text: addClaimText,
    href: addClaimHref,
    classes: "govuk-button--secondary"
  }) }}

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />
    {{ govukButton({ text: "Continue" }) }}
  </form>
{% endblock %}

{% extends "live-animals/shared/layout.njk" %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "live-animals/shared/save-actions.njk" import saveActions %}

{% block journeyContent %}
  {% include "live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ copy.title }}</h1>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukSelect({
      id: "portOfExit",
      name: "portOfExit",
      label: { text: copy.port.label, classes: "govuk-label--s" },
      hint: { text: copy.port.hint },
      value: values.portOfExit,
      errorMessage: errors.portOfExit and { text: errors.portOfExit },
      items: portItems
    }) }}

    {{ saveActions(hubHref, copy = sharedCopy.saveActions) }}
  </form>
{% endblock %}

{# Accompanying-documents index — doc-major. One summary block per
   document with per-row Change links (to that doc's specific page) and
   a per-doc Delete form. Add-a-document button mints a new doc and
   redirects into its first per-doc page (see accompanyingDocumentsAddController).
   The Add button is disabled once the user hits maxEntries. #}

{% extends "shared/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block journeyContent %}
  <h1 class="govuk-heading-l">{{ heading }}</h1>

  {% if lead %}<p class="govuk-body">{{ lead }}</p>{% endif %}

  {% if docs and docs.length %}
    {% for doc in docs %}
      <h2 class="govuk-heading-m govuk-!-margin-top-6">{{ doc.title }}</h2>
      {{ govukSummaryList({ rows: doc.rows }) }}
      <form method="post" action="{{ doc.deleteHref }}" novalidate class="govuk-!-margin-bottom-6">
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        {{ govukButton({
          text: doc.deleteButtonText,
          classes: "govuk-button--warning govuk-button--secondary",
          attributes: { "aria-label": doc.deleteVisuallyHiddenText }
        }) }}
      </form>
    {% endfor %}
  {% else %}
    <p class="govuk-body">{{ emptyText }}</p>
  {% endif %}

  {% if capText %}
    <p class="govuk-body">{{ capText }}</p>
  {% endif %}

  <form method="post" action="{{ addHref }}" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />
    {{ govukButton({
      text: addButtonText,
      classes: "govuk-button--secondary",
      disabled: atCap
    }) }}
  </form>

  {% if backLink %}
    <p class="govuk-body">
      <a class="govuk-link" href="{{ backLink }}">{{ backLinkText }}</a>
    </p>
  {% endif %}
{% endblock %}

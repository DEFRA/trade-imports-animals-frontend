{% extends layout %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block journeyContent %}
  {% if errorSummary %}
    {{ govukErrorSummary({ titleText: "There is a problem", errorList: errorSummary }) }}
  {% endif %}

  <h1 class="govuk-heading-l">{{ section.title }}</h1>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {% include "standalone/spike-a/templates/partials/" + section.slug + ".njk" %}

    {{ govukButton({ text: submitText or "Save and continue" }) }}
  </form>
{% endblock %}

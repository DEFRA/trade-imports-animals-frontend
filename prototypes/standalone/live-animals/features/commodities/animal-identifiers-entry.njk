{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <span class="govuk-caption-l">{{ commodity }}</span>
  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <p class="govuk-body">Enter at least one identifier for this animal.</p>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {% for field in fields %}
      {{ govukInput({
        id: field.id,
        name: field.id,
        label: { text: field.label, classes: "govuk-label--s" },
        hint: field.hint and { text: field.hint },
        classes: "govuk-input--width-20",
        value: field.value,
        errorMessage: field.error and { text: field.error }
      }) }}
    {% endfor %}

    {% if showAddress %}
      <h2 class="govuk-heading-m">Permanent address</h2>
      <p class="govuk-body">A permanent address is required for this animal.</p>

      {{ govukInput({
        id: "nameOrOrganisationName", name: "nameOrOrganisationName",
        label: { text: "Name or organisation name" },
        autocomplete: "name",
        value: addressValues.nameOrOrganisationName,
        errorMessage: addressErrors.nameOrOrganisationName and { text: addressErrors.nameOrOrganisationName }
      }) }}

      {{ govukInput({
        id: "addressLine1", name: "addressLine1",
        label: { text: "Address line 1" },
        autocomplete: "address-line1",
        value: addressValues.addressLine1,
        errorMessage: addressErrors.addressLine1 and { text: addressErrors.addressLine1 }
      }) }}

      {{ govukInput({
        id: "addressLine2", name: "addressLine2",
        label: { text: "Address line 2 (optional)" },
        autocomplete: "address-line2",
        value: addressValues.addressLine2,
        errorMessage: addressErrors.addressLine2 and { text: addressErrors.addressLine2 }
      }) }}

      {{ govukInput({
        id: "townOrCity", name: "townOrCity",
        label: { text: "Town or city" },
        classes: "govuk-!-width-two-thirds",
        autocomplete: "address-level2",
        value: addressValues.townOrCity,
        errorMessage: addressErrors.townOrCity and { text: addressErrors.townOrCity }
      }) }}

      {{ govukInput({
        id: "county", name: "county",
        label: { text: "County (optional)" },
        classes: "govuk-!-width-two-thirds",
        value: addressValues.county,
        errorMessage: addressErrors.county and { text: addressErrors.county }
      }) }}

      {{ govukInput({
        id: "postalOrZipCode", name: "postalOrZipCode",
        label: { text: "Postal or zip code" },
        classes: "govuk-input--width-10",
        autocomplete: "postal-code",
        value: addressValues.postalOrZipCode,
        errorMessage: addressErrors.postalOrZipCode and { text: addressErrors.postalOrZipCode }
      }) }}

      {{ govukSelect({
        id: "country", name: "country",
        label: { text: "Country" },
        items: addressCountryItems,
        errorMessage: addressErrors.country and { text: addressErrors.country }
      }) }}

      {{ govukInput({
        id: "telephoneNumber", name: "telephoneNumber",
        label: { text: "Telephone number" },
        type: "tel",
        classes: "govuk-input--width-20",
        autocomplete: "tel",
        value: addressValues.telephoneNumber,
        errorMessage: addressErrors.telephoneNumber and { text: addressErrors.telephoneNumber }
      }) }}

      {{ govukInput({
        id: "emailAddress", name: "emailAddress",
        label: { text: "Email address" },
        type: "email",
        autocomplete: "email",
        value: addressValues.emailAddress,
        errorMessage: addressErrors.emailAddress and { text: addressErrors.emailAddress }
      }) }}
    {% endif %}

    {{ govukButton({ text: "Add animal" }) }}
  </form>
{% endblock %}

{% extends 'layouts/page.njk' %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  {{ appReferenceNumberCaption({ referenceNumber: referenceNumber }) }}

  {{ appHeading({ text: "Notification details" }) }}

  <div id="success-banner" hidden>
    <div class="govuk-notification-banner govuk-notification-banner--success" role="alert"
         aria-labelledby="success-banner-title" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="success-banner-title">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-body">Notification deleted. Redirecting to your dashboard...</p>
      </div>
    </div>
  </div>

  <div id="error-banner" hidden>
    <div class="govuk-notification-banner" role="alert"
         aria-labelledby="error-banner-title" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="error-banner-title">Important</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-body">There was a problem deleting the notification. Please try again.</p>
      </div>
    </div>
  </div>

  {% if copyError %}
    <div class="govuk-notification-banner" role="alert"
         aria-labelledby="copy-error-banner-title" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="copy-error-banner-title">Important</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-body">There was a problem copying this notification. Please try again.</p>
      </div>
    </div>
  {% endif %}

  {% if errorMessage %}
    {{ govukInsetText({ text: errorMessage }) }}
  {% else %}

  {% if status === 'DRAFT' or status === 'SUBMITTED' %}
    <input type="hidden" id="crumb-value" value="{{ crumb }}">
    {{ govukButton({
      text: "Copy as new",
      classes: "govuk-button--secondary",
      attributes: {
        id: "copy-btn",
        "data-copy-ref": referenceNumber
      }
    }) }}

    {{ govukButton({
      text: "Delete",
      classes: "govuk-button--warning",
      attributes: {
        id: "delete-btn",
        "data-reference-number": referenceNumber
      }
    }) }}

    <dialog id="delete-dialog" aria-labelledby="dialog-title" aria-modal="true">
      <h2 class="govuk-heading-m" id="dialog-title">Delete this notification?</h2>
      <p class="govuk-body">This will remove the notification from your dashboard. You cannot undo this action.</p>
      {{ govukButton({ text: "Yes, delete", classes: "govuk-button--warning", attributes: { id: "confirm-delete-btn" } }) }}
      {{ govukButton({ text: "Cancel", classes: "govuk-button--secondary", attributes: { id: "cancel-delete-btn", autofocus: "true" } }) }}
    </dialog>
  {% endif %}

  <p class="govuk-body">Date created: <strong>{{ dateCreated }}</strong></p>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {# ── Origin ────────────────────────────────────────────────────── #}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">Where is this consignment coming from?</h2>
          {% if status === 'DRAFT' %}
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link" href="/origin">Change<span class="govuk-visually-hidden"> where this consignment is coming from</span></a>
              </li>
            </ul>
          {% endif %}
        </div>
        <div class="govuk-summary-card__content">
          {{ govukSummaryList({
            rows: [
              { key: { text: "Country of origin" },             value: { text: origin.countryOfOrigin } },
              { key: { text: "Region of consignment" },         value: { text: origin.regionOfConsignment } },
              { key: { text: "Your internal reference number" }, value: { text: origin.internalReference } }
            ]
          }) }}
        </div>
      </div>

      {# ── Commodities ───────────────────────────────────────────────── #}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">Your commodities</h2>
          {% if status === 'DRAFT' %}
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link" href="/commodities">Change<span class="govuk-visually-hidden"> your commodities</span></a>
              </li>
            </ul>
          {% endif %}
        </div>
        <div class="govuk-summary-card__content">
          <p class="govuk-body"><strong>{{ commodity.name }}</strong></p>
          {% if commodity.species and commodity.species.length %}
            <table class="govuk-table">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Animal name</th>
                  <th scope="col" class="govuk-table__header">Ear tag</th>
                  <th scope="col" class="govuk-table__header">Passport</th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                {% for animal in commodity.species %}
                  <tr class="govuk-table__row">
                    <td class="govuk-table__cell">{{ animal.name }}</td>
                    <td class="govuk-table__cell">{{ animal.earTag }}</td>
                    <td class="govuk-table__cell">{{ animal.passport }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% endif %}
        </div>
      </div>

      {# ── Additional information ─────────────────────────────────────── #}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">Additional information details</h2>
          {% if status === 'DRAFT' %}
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link" href="/additional-details">Change<span class="govuk-visually-hidden"> additional information details</span></a>
              </li>
            </ul>
          {% endif %}
        </div>
        <div class="govuk-summary-card__content">
          {{ govukSummaryList({
            rows: [
              { key: { text: "Certified for" },    value: { text: additionalDetails.certifiedFor } },
              { key: { text: "Unweaned animals" }, value: { text: additionalDetails.unweanedAnimals } }
            ]
          }) }}
        </div>
      </div>

      {# ── Reason for import ─────────────────────────────────────────── #}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">Reason for importing the animals</h2>
          {% if status === 'DRAFT' %}
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link" href="/import-reason">Change<span class="govuk-visually-hidden"> reason for importing the animals</span></a>
              </li>
            </ul>
          {% endif %}
        </div>
        <div class="govuk-summary-card__content">
          {{ govukSummaryList({
            rows: [
              { key: { text: "Main reason for importing the animals" }, value: { text: reasonForImport } }
            ]
          }) }}
        </div>
      </div>

      {# ── Addresses ─────────────────────────────────────────────────── #}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">Addresses</h2>
          {% if status === 'DRAFT' %}
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link" href="/addresses">Change<span class="govuk-visually-hidden"> addresses</span></a>
              </li>
            </ul>
          {% endif %}
        </div>
        <div class="govuk-summary-card__content">
          {{ govukSummaryList({
            rows: [
              { key: { text: "Place of origin" },                value: { text: addresses.placeOfOrigin } },
              { key: { text: "Consignor" },                      value: { html: addresses.consignor | nl2br } },
              { key: { text: "Consignee" },                      value: { html: addresses.consignee | nl2br } },
              { key: { text: "Importer" },                       value: { html: addresses.importer | nl2br } },
              { key: { text: "Place of destination" },           value: { html: addresses.placeOfDestination | nl2br } },
              { key: { text: "Contact details for consignment" }, value: { html: addresses.contactDetails | nl2br } }
            ]
          }) }}
        </div>
      </div>

      {# ── CPH ───────────────────────────────────────────────────────── #}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">County Parish Holding number (CPH)</h2>
          {% if status === 'DRAFT' %}
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link" href="/cph-number">Change<span class="govuk-visually-hidden"> County Parish Holding number</span></a>
              </li>
            </ul>
          {% endif %}
        </div>
        <div class="govuk-summary-card__content">
          {{ govukSummaryList({
            rows: [
              { key: { text: "County Parish Holding number (CPH)" }, value: { text: cphNumber } }
            ]
          }) }}
        </div>
      </div>

      {# ── Transport ─────────────────────────────────────────────────── #}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">Transport details</h2>
          {% if status === 'DRAFT' %}
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link" href="/transporters">Change<span class="govuk-visually-hidden"> transport details</span></a>
              </li>
            </ul>
          {% endif %}
        </div>
        <div class="govuk-summary-card__content">
          {{ govukSummaryList({
            rows: [
              { key: { text: "Transporter name" },              value: { text: transport.transporterName } },
              { key: { text: "Transporter address" },           value: { html: transport.transporterAddress | nl2br } },
              { key: { text: "Type" },                          value: { text: transport.type } },
              { key: { text: "Approval number" },               value: { text: transport.approvalNumber } },
              { key: { text: "Port of entry" },                 value: { text: transport.portOfEntry } },
              { key: { text: "Arrival date at destination" },   value: { text: transport.arrivalDate } }
            ]
          }) }}
        </div>
      </div>

      {# ── Accompanying documents ────────────────────────────────────── #}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">Accompanying documents</h2>
          {% if status === 'DRAFT' %}
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link" href="/accompanying-documents">Change<span class="govuk-visually-hidden"> accompanying documents</span></a>
              </li>
            </ul>
          {% endif %}
        </div>
        <div class="govuk-summary-card__content">
          {% if documents and documents.length %}
            <table class="govuk-table">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Document type</th>
                  <th scope="col" class="govuk-table__header">Document reference</th>
                  <th scope="col" class="govuk-table__header">Valid until</th>
                  <th scope="col" class="govuk-table__header">Attachments</th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                {% for doc in documents %}
                  <tr class="govuk-table__row">
                    <td class="govuk-table__cell">{{ doc.type }}</td>
                    <td class="govuk-table__cell">{{ doc.reference }}</td>
                    <td class="govuk-table__cell">{{ doc.validUntil }}</td>
                    <td class="govuk-table__cell">{{ doc.attachments }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <p class="govuk-body">Not yet added</p>
          {% endif %}
        </div>
      </div>

    </div>
  </div>

  {% if status === 'DRAFT' %}
    {{ govukButton({
      text: "Confirm and submit",
      href: "/declaration"
    }) }}
  {% endif %}

  {% endif %}
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  {% if status === 'DRAFT' or status === 'SUBMITTED' %}
    <script type="module" src="{{ getAssetPath('notificationView.js') }}"></script>
  {% endif %}
{% endblock %}

{% extends "govuk/template.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% set spikeHome = "/prototype-standalone/live-animals" %}

{% block head %}
  <meta name="csrf-token" content="{{ crumb }}">
  <link href="{{ getAssetPath('stylesheets/application.scss') }}" rel="stylesheet">
{% endblock %}

{% block pageTitle %}{% if errorSummary %}Error: {% endif %}{{ pageTitle }} | Import notification service (standalone){% endblock %}

{% block govukServiceNavigation %}
  {{ govukServiceNavigation({
    serviceName: "Import notification service (standalone)",
    serviceUrl: spikeHome
  }) }}
{% endblock %}

{% block beforeContent %}
  {{ govukPhaseBanner({
    tag: { text: "Prototype" },
    html: 'Obligations v2 spike standalone — a non-functional prototype, not a real service.'
  }) }}
  {{ govukBreadcrumbs({
    items: breadcrumbs if breadcrumbs else [
      { text: "Prototypes", href: "/prototype-standalone" },
      { text: "Obligations v2 (standalone)", href: spikeHome },
      { text: pageTitle }
    ]
  }) }}
  {% if backLink %}
    {{ govukBackLink({ text: "Back", href: backLink }) }}
  {% endif %}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if journeyStrip %}
        <div class="app-journey-strip govuk-!-margin-bottom-4">
          {{ govukTag({ text: journeyStrip.status.text, classes: journeyStrip.status.classes }) }}
          <span class="govuk-body govuk-!-font-weight-bold">{{ journeyStrip.reference }}</span>
        </div>
      {% endif %}
      {% block journeyContent %}{% endblock %}
    </div>
  </div>
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ getAssetPath('application.js') }}"></script>
{% endblock %}

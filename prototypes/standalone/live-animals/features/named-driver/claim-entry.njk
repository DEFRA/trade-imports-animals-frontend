{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {% set windscreenHtml %}
      {{ govukRadios({
        name: "windscreenProvider",
        fieldset: { legend: { text: "Which approved repairer did you use?", classes: "govuk-fieldset__legend--s" } },
        items: windscreenOptions,
        errorMessage: errors.windscreenProvider and { text: errors.windscreenProvider }
      }) }}
    {% endset %}

    {{ govukRadios({
      name: "claimType",
      fieldset: { legend: { text: "What type of claim was it?", classes: "govuk-fieldset__legend--s" } },
      items: [
        { value: "accident", text: "Accident", checked: values.claimType == "accident" },
        { value: "theft", text: "Theft", checked: values.claimType == "theft" },
        { value: "windscreen", text: "Windscreen", checked: values.claimType == "windscreen", conditional: { html: windscreenHtml } },
        { value: "other", text: "Something else", checked: values.claimType == "other" }
      ]
    }) }}

    {{ govukInput({
      id: "claimAmount", name: "claimAmount",
      label: { text: "Approximate claim amount" },
      classes: "govuk-input--width-5",
      inputmode: "numeric",
      prefix: { text: "£" },
      value: values.claimAmount,
      errorMessage: errors.claimAmount and { text: errors.claimAmount }
    }) }}

    {{ govukButton({ text: buttonText }) }}
  </form>
{% endblock %}

{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "standalone/live-animals/features/commodities/_selected-commodities-table.njk" import selectedCommoditiesTable %}
{% from "standalone/live-animals/features/commodities/_species-quantities.njk" import speciesQuantityGroup %}
{% from "standalone/live-animals/shared/save-actions.njk" import saveActions %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ copy.title }}</h1>

  {% if hasLines %}
    {{ selectedCommoditiesTable(groups, copy.table) }}
  {% else %}
    <p class="govuk-body">{{ copy.emptyText }}</p>
  {% endif %}

  <p class="govuk-body">
    <a class="govuk-link" href="{{ addHref }}">{{ addText }}</a>
  </p>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {% for group in groups %}
      {{ speciesQuantityGroup(group, copy) }}
    {% endfor %}

    {{ saveActions(hubHref, copy = sharedCopy.saveActions) }}
  </form>
{% endblock %}

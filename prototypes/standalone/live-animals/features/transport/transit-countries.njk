{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "standalone/live-animals/shared/save-actions.njk" import saveActions %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <p class="govuk-body">Countries the consignment will travel through are countries between the country of origin and the destination country.</p>
  <p class="govuk-body">This does not include the United Kingdom.</p>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {% for items in countryRows %}
      {% if loop.first %}
        {{ govukSelect({
          id: "transitedCountries",
          name: "transitedCountries",
          label: { text: "Enter all countries", classes: "govuk-label--s" },
          hint: { text: "You can add up to 12 countries" },
          errorMessage: errors.transitedCountries and { text: errors.transitedCountries },
          items: items
        }) }}
      {% else %}
        {{ govukSelect({
          id: "transitedCountries-" + loop.index,
          name: "transitedCountries",
          label: { text: "Country " + loop.index, classes: "govuk-visually-hidden" },
          items: items
        }) }}
      {% endif %}
    {% endfor %}

    {% if canAddAnother %}
      {{ govukButton({
        text: "Add another country",
        classes: "govuk-button--secondary",
        name: "addCountry",
        value: "add"
      }) }}
    {% endif %}

    {{ saveActions(hubHref) }}
  </form>
{% endblock %}

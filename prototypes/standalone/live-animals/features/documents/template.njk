{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/file-upload/macro.njk" import govukFileUpload %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "standalone/live-animals/shared/save-actions.njk" import saveActions %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ copy.title }}</h1>

  <form method="post" enctype="multipart/form-data" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukInput({
      id: "accompanyingDocumentReference",
      name: "accompanyingDocumentReference",
      label: { text: copy.reference.label, classes: "govuk-label--s" },
      hint: { text: copy.reference.hint },
      classes: "govuk-input--width-20",
      value: values.accompanyingDocumentReference,
      errorMessage: errors.accompanyingDocumentReference and { text: errors.accompanyingDocumentReference }
    }) }}

    {{ govukDateInput(dateOfIssue) }}

    {%- set fileHintHtml -%}
      <p class="govuk-!-font-weight-bold govuk-!-margin-bottom-1">{{ copy.file.mustBe }}</p>
      <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
        <li>{{ copy.file.smallerThan }} {{ maxFileSizeLabel }}</li>
        <li>{{ copy.file.a }} {{ allowedFileTypesHint }}</li>
      </ul>
    {%- endset -%}

    {{ govukFileUpload({
      id: "file",
      name: "file",
      label: { text: copy.file.label, classes: "govuk-label--s" },
      hint: { html: fileHintHtml },
      attributes: { accept: acceptAttribute },
      errorMessage: errors.file and { text: errors.file }
    }) }}

    {{ govukButton({
      text: copy.addAnother,
      classes: "govuk-button--secondary",
      name: "action",
      value: "add"
    }) }}

    {% if hasDocuments %}
      <div id="documents-added">
        {{ govukTable({
          caption: copy.table.caption,
          captionClasses: "govuk-visually-hidden",
          head: [
            { text: copy.table.reference },
            { text: copy.table.type },
            { text: copy.table.dateOfIssue },
            { text: copy.table.status },
            { html: '<span class="govuk-visually-hidden">' + copy.table.actionsHidden + '</span>' }
          ],
          rows: rows
        }) }}
      </div>
      {% if anyPending %}
        <p class="govuk-body">
          <a href="{{ refreshHref }}" class="govuk-link">{{ copy.refreshStatus }}</a>
        </p>
      {% endif %}
      {% if timedOut %}
        <p class="govuk-hint">{{ copy.stillChecking }}</p>
      {% endif %}
    {% else %}
      <p class="govuk-body">{{ copy.empty }}</p>
    {% endif %}

    {{ saveActions(hubHref, { text: copy.continueButton, name: "action", value: "continue" }, sharedCopy.saveActions) }}
  </form>
{% endblock %}

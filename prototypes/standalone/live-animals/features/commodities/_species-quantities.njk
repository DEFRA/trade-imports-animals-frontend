{% from "govuk/components/input/macro.njk" import govukInput %}

{# One block per commodity group: heading, then per-species quantity inputs
   for every line of that commodity (design 01-14/15, "same animal different
   genus" renders one sub-block per species). #}
{% macro speciesQuantityGroup(group, copy) %}
  <h2 class="govuk-heading-m">{{ group.name }} ({{ group.code }})</h2>
  {% for line in group.lines %}
    <h3 class="govuk-heading-s">{{ line.speciesText }}</h3>

    {{ govukInput({
      id: line.animalsField,
      name: line.animalsField,
      label: { text: copy.animals.label },
      hint: { text: copy.animals.hint },
      classes: "govuk-input--width-5",
      inputmode: "numeric",
      value: line.animalsValue,
      errorMessage: line.animalsError and { text: line.animalsError }
    }) }}

    {% if group.showPackages %}
      {{ govukInput({
        id: line.packagesField,
        name: line.packagesField,
        label: { text: copy.packages.label },
        hint: { text: copy.packages.hint },
        classes: "govuk-input--width-5",
        inputmode: "numeric",
        value: line.packagesValue,
        errorMessage: line.packagesError and { text: line.packagesError }
      }) }}
    {% endif %}
  {% endfor %}
  <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible" />
{% endmacro %}

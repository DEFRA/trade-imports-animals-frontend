{% extends 'layouts/page.njk' %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}


{% block pageContent %}

  {{ govukBackLink({
    text: "Back",
    href: "/commodities/details"
  }) }}

  {{ appReferenceNumberCaption({ referenceNumber: referenceNumber }) }}
  {{ appHeading({ pageTitle: "Description of the goods", heading: "Enter animal identification details" }) }}

    <div class="govuk-body" data-testid="app-page-body">

      {% if errorList %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: errorList
        }) }}
      {% endif %}

      <form method="post" id="commodity-details-form" name="commodity-details-form" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        <input type="hidden" id="totalNoOfAnimals" name="totalNoOfAnimals" value="{{ totalNoOfAnimals }}" />
        <input type="hidden" id="totalNoOfPackages" name="totalNoOfPackages" value="{{ totalNoOfPackages }}" />

        <div class="govuk-hint">You must enter all animal identification details into the notification before arrival at the port of entry</div>
        <table class="govuk-table">
          <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Commodity code</th>
            <th scope="col" class="govuk-table__header">Description</th>
            <th scope="col" class="govuk-table__header">Species and type</th>
            <th scope="col" class="govuk-table__header">Number of animals</th>
          </tr>
          </thead>
          <tbody class="govuk-table__body">
          {% for species in speciesLst %}
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">0102</td>
              <td class="govuk-table__cell">Live bovine animals</td>
              <td class="govuk-table__cell">{{ species.text }}, {{ typeOfCommodity }}</td>
              <td class="govuk-table__cell">{{ species.noOfAnimals }}</td>
            </tr>
          {% endfor %}
          </tbody>
        </table>

        {% for species in speciesLst %}
          <span class="govuk-caption-m">{{ species.text }}, {{ typeOfCommodity }} identification details</span>
          <table class="govuk-table">
            <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">Animal</th>
              <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">Ear tag</th>
              <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">Passport</th>
            </tr>
            </thead>
            <tbody class="govuk-table__body">
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">{{ species.text }}, {{ typeOfCommodity }}</td>
              <td class="govuk-table__cell">
                {{ govukInput({
                  id: "earTag-" + species.value,
                  name: "earTag-" + species.value,
                  value: species.earTag,
                  label: {
                    text: "Ear tag for " + species.text,
                    classes: "govuk-visually-hidden"
                  }
                }) }}
              </td>
              <td class="govuk-table__cell">
                {{ govukInput({
                  id: "passport-" + species.value,
                  name: "passport-" + species.value,
                  value: species.passport,
                  label: {
                    text: "Passport for " + species.text,
                    classes: "govuk-visually-hidden"
                  }
                }) }}
              </td>
            </tr>
            </tbody>
          </table>
        {% endfor %}

        <div class="govuk-button-group">
          {{ govukButton({
            text: "Save and continue"
          }) }}
        </div>
      </form>
    </div>

{% endblock %}

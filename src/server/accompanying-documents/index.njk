{% extends 'layouts/page.njk' %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/file-upload/macro.njk" import govukFileUpload %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/details/macro.njk" import govukDetails %}

{% block head %}
  {{ super() }}
  <noscript>
    {% if anyPending and not timedOut %}
      <meta http-equiv="refresh" content="3; url=?attempt={{ nextAttempt }}">
    {% endif %}
  </noscript>
{% endblock %}

{% block content %}
  {{ appHeading({
    text: "Accompanying documents"
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errorList %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: errorList
        }) }}
      {% endif %}

      <p class="govuk-body">Where an ITAHC applies, you need to upload it for this notification. If you do not have it when you submit, you must add it to your notification once you receive it. You can also return to your notification later to upload any other documents you still need.</p>

      <p class="govuk-body">If you already have documents, you can add them below. For example:</p>

      <ul class="govuk-list govuk-list--bullet">
        <li>ITAHC</li>
        <li>import licences or authorisations</li>
        <li>commercial documents or invoices</li>
      </ul>

      {{ govukDetails({
        summaryText: "Check which additional documents you may need to upload",
        text: "You may also need to upload a veterinary health certificate, air waybill, commercial invoice, or other supporting documentation depending on the type of animals being imported."
      }) }}

      {% if documents and documents.length %}
        <h2 class="govuk-heading-m" id="documents-added">Documents added</h2>

        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Document</th>
              <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">Status</th>
              <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">
                <span class="govuk-visually-hidden">Actions</span>
              </th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for doc in documents %}
              <tr class="govuk-table__row" data-upload-id="{{ doc.uploadId }}" data-scan-status="{{ doc.scanStatus }}">
                <td class="govuk-table__cell">
                  {{ doc.filename }}
                  {% if doc.documentType or doc.documentReference %}
                    <div class="govuk-hint govuk-!-margin-bottom-0">{{ doc.documentType }}{% if doc.documentReference %} — {{ doc.documentReference }}{% endif %}</div>
                  {% endif %}
                </td>
                <td class="govuk-table__cell">
                  {% if doc.scanStatus === 'COMPLETE' %}
                    {{ govukTag({ text: "Safe", classes: "govuk-tag--green" }) }}
                  {% elif doc.scanStatus === 'REJECTED' %}
                    {{ govukTag({ text: "Virus found", classes: "govuk-tag--red" }) }}
                  {% else %}
                    {{ govukTag({ text: "Checking", classes: "govuk-tag--blue" }) }}
                  {% endif %}
                </td>
                <td class="govuk-table__cell govuk-!-text-align-right">
                  <form method="post" action="/accompanying-documents/remove">
                    <input type="hidden" name="crumb" value="{{ crumb }}">
                    <input type="hidden" name="uploadId" value="{{ doc.uploadId }}">
                    <button type="submit" class="govuk-link govuk-body app-button-as-link">
                      Remove<span class="govuk-visually-hidden"> {{ doc.filename }}</span>
                    </button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        {% if anyPending %}
          <p id="js-refresh-fallback" class="govuk-body">
            <a href="?attempt={{ nextAttempt }}" class="govuk-link">Refresh virus scan status</a>
          </p>
        {% endif %}

        {% if timedOut %}
          <p class="govuk-hint">
            Still checking some documents.
            <a href="?attempt={{ nextAttempt }}" class="govuk-link">Refresh to check status</a>
          </p>
        {% endif %}

      {% endif %}

      <div data-testid="app-page-body">

        {% if documents and documents.length %}
          <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">
        {% endif %}

        <h2 class="govuk-heading-m">Document {{ (documents.length + 1) if documents else 1 }}</h2>

        <form method="post" enctype="multipart/form-data" novalidate>
          <input type="hidden" name="crumb" value="{{ crumb }}"/>

          {{ govukSelect({
            id: "documentType",
            name: "documentType",
            label: {
              text: "Document type",
              classes: "govuk-label--s"
            },
            value: documentType,
            errorMessage: fieldErrors.documentType if fieldErrors,
            items: [
              { value: "", text: "Select document type" },
              { value: "ITAHC", text: "Intra-Trade Animal Health Certificate (ITAHC)" },
              { value: "VETERINARY_HEALTH_CERTIFICATE", text: "Veterinary health certificate" }
            ]
          }) }}

          {{ govukInput({
            label: {
              text: "Document reference",
              classes: "govuk-label--s"
            },
            id: "documentReference",
            name: "documentReference",
            value: documentReference if documentReference,
            errorMessage: fieldErrors.documentReference if fieldErrors
          }) }}

          {{ govukDateInput({
            id: "issueDate",
            namePrefix: "issueDate",
            fieldset: {
              legend: {
                text: "Date of issue",
                classes: "govuk-fieldset__legend--s"
              }
            },
            hint: {
              text: "For example, 27 3 2024"
            },
            errorMessage: fieldErrors["issueDate-day"] if fieldErrors,
            items: [
              {
                name: "day",
                classes: "govuk-input--width-2",
                value: issueDate_day if issueDate_day
              },
              {
                name: "month",
                classes: "govuk-input--width-2",
                value: issueDate_month if issueDate_month
              },
              {
                name: "year",
                classes: "govuk-input--width-4",
                value: issueDate_year if issueDate_year
              }
            ]
          }) }}

          {{ govukFileUpload({
            id: "file",
            name: "file",
            label: {
              text: "Attachment",
              classes: "govuk-label--s"
            },
            hint: {
              html: '<p class="govuk-!-font-weight-bold govuk-!-margin-bottom-1">Your file must be:</p><ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0"><li>smaller than 50MB</li><li>PDF, DOC, DOCX, JPEG, PNG or XLS</li><li>ZIP files are not allowed for security reasons</li></ul>'
            },
            errorMessage: fieldErrors.file if fieldErrors
          }) }}

          <div class="govuk-button-group govuk-!-margin-bottom-0">
            {{ govukButton({
              text: "Add attachment",
              classes: "govuk-button--secondary"
            }) }}
          </div>
        </form>

      </div>

      <div class="govuk-button-group">
        {% if canContinue %}
          {{ govukButton({ text: "Save and continue", href: "/" }) }}
        {% else %}
          {{ govukButton({ text: "Save and continue", disabled: true }) }}
        {% endif %}
      </div>

    </div>
  </div>

{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('accompanyingDocuments.js') }}"></script>
{% endblock %}

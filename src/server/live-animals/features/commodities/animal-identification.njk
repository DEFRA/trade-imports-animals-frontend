{% extends "live-animals/shared/layout.njk" %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "live-animals/features/commodities/_identification-card.njk" import identificationCard %}
{% from "live-animals/shared/save-actions.njk" import saveActions %}

{% block journeyContent %}
  {% include "live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ copy.title }}</h1>

  {{ govukInsetText({
    text: copy.inset
  }) }}

  {% if hasLines %}
    <form method="post" novalidate>
      <input type="hidden" name="crumb" value="{{ crumb }}" />

      <button type="submit" name="action" value="finish" class="govuk-visually-hidden" aria-hidden="true" tabindex="-1">{{ copy.saveAndFinish }}</button>

      {% for card in cards %}
        {{ identificationCard(card, copy) }}
      {% endfor %}

      {{ saveActions(hubHref, { text: copy.saveAndFinish, name: "action", value: "finish" }, sharedCopy.saveActions) }}
    </form>
  {% else %}
    <p class="govuk-body">{{ copy.emptyText }}</p>
    <p class="govuk-body">
      <a class="govuk-link" href="{{ addHref }}">{{ copy.addCommodity }}</a>
    </p>
  {% endif %}
{% endblock %}

{% extends 'layouts/page.njk' %}

{% block pageContent %}

  {{ govukBackLink({
    text: "Back",
    href: "/addresses"
  }) }}

  {{ appReferenceNumberCaption({ referenceNumber: referenceNumber }) }}
  {{ appHeading({ pageTitle: "Address", heading: "Search for an existing consignor or exporter" }) }}

      <div class="govuk-body" data-testid="app-page-body">

        <form method="post" novalidate>
          <input type="hidden" name="crumb" value="{{ crumb }}" />

          <div class="govuk-fieldset">
            <div class="govuk-form-group">
              <fieldset class="govuk-fieldset">
                <table class="govuk-table govuk-table--small-text-until-tablet">
                  <thead class="govuk-table__head">
                  <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header">Name</th>
                    <th scope="col" class="govuk-table__header">Address</th>
                    <th scope="col" class="govuk-table__header">Country</th>
                    <th scope="col" class="govuk-table__header"></th>
                  </tr>
                  </thead>
                  <tbody class="govuk-table__body">
                  {% for consignor in consignors %}
                    <tr class="govuk-table__row">
                      <th scope="row" class="govuk-table__header">{{ consignor.name }}</th>
                      <td class="govuk-table__cell">
                        {{ consignor.address.addressLine1 }}{% if consignor.address.addressLine2 %}, {{ consignor.address.addressLine2 }}{% endif %}{% if consignor.address.addressLine3 %}, {{ consignor.address.addressLine3 }}{% endif %}
                      </td>
                      <td class="govuk-table__cell">{{ consignor.address.country }}</td>
                      <td class="govuk-table__cell">
                        <a href="/addresses?selectedConsignor={{ loop.index0 }}" id="selectedConsignor-{{ loop.index0 }}">Select</a>
                      </td>
                    </tr>
                  {% endfor %}
                  </tbody>
                </table>
              </fieldset>
            </div>
          </div>
        </form>
      </div>
{% endblock %}

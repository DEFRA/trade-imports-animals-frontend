{% extends "live-animals/shared/layout.njk" %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}

{% block journeyContent %}
  {% set referencePanelHtml %}{{ copy.panel.referencePrefix }}<br><strong>{{ referenceNumber }}</strong>{% endset %}
  {{ govukPanel({
    titleText: copy.panel.title,
    html: referencePanelHtml
  }) }}

  <p class="govuk-body">{{ copy.dateOfDeclaration }} {{ submissionDate }}</p>

  <h2 class="govuk-heading-m">{{ copy.transporting.heading }}</h2>
  <p class="govuk-body">{{ copy.transporting.direct }}</p>
  <p class="govuk-body">{{ copy.transporting.inspection }}</p>
  <p class="govuk-body">{{ copy.transporting.stay }}</p>
  <ul class="govuk-list govuk-list--bullet">
    {% for item in copy.transporting.stayItems %}
      <li>{{ item }}</li>
    {% endfor %}
  </ul>

  <h2 class="govuk-heading-m">{{ copy.viewOrAmend.heading }}</h2>
  <p class="govuk-body">{{ copy.viewOrAmend.body }}</p>
  <p class="govuk-body">
    <a class="govuk-link" href="{{ dashboardHref }}">{{ copy.viewOrAmend.dashboardLink }}</a>
  </p>

  <h2 class="govuk-heading-m">{{ copy.help.heading }}</h2>
  <p class="govuk-body">{{ copy.help.importsEmailPrefix }} <a class="govuk-link" href="mailto:importsriskmanagement@apha.gov.uk">importsriskmanagement@apha.gov.uk</a>.</p>
  <p class="govuk-body">{{ copy.help.technicalHelp }}</p>
  <ul class="govuk-list govuk-list--bullet">
    <li>{{ copy.help.telephone }}</li>
    <li>{{ copy.help.emailPrefix }} <a class="govuk-link" href="mailto:APHAServiceDesk@apha.gov.uk">APHAServiceDesk@apha.gov.uk</a></li>
  </ul>
  <p class="govuk-body">{{ copy.help.openingHours }}</p>
  <p class="govuk-body">{{ copy.help.customsPrefix }} <a class="govuk-link" href="https://www.gov.uk/government/organisations/hm-revenue-customs/contact">{{ copy.help.customsLink }}</a>.</p>
  <p class="govuk-body">
    <a class="govuk-link" href="https://www.gov.uk/call-charges">{{ copy.help.callCharges }}</a>
  </p>
{% endblock %}

{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}

{% block journeyContent %}
  {% if submitted %}
    {{ govukPanel({ titleText: "Notification submitted" }) }}

    <p class="govuk-body">Date of declaration: {{ submissionDate }}</p>

    <h2 class="govuk-heading-m">What happens next</h2>
    <p class="govuk-body">Nothing — this is a prototype. Your answers are held in memory for the lifetime of the app so you can see the journey persist data.</p>

    <p class="govuk-body">
      <a class="govuk-link" href="{{ returnHref }}">Return to the dashboard</a>
    </p>
  {% else %}
    {% include "standalone/live-animals/shared/error-summary.njk" %}

    <h1 class="govuk-heading-l">{{ heading }}</h1>

    <p class="govuk-body"><strong>I confirm I am responsible for this notification.</strong></p>

    <p class="govuk-body">I am responsible from the submission of this notification to when it enters Great Britain.</p>

    <p class="govuk-body">I am authorised as being accountable for these things if raising notifications on behalf of a third party.</p>

    <p class="govuk-body">I can legally act on behalf of a third party in relation to the conditions of this declaration.</p>

    <form method="post" novalidate>
      <input type="hidden" name="crumb" value="{{ crumb }}" />

      {{ govukCheckboxes({
        name: "declaration",
        errorMessage: errors.declaration and { text: errors.declaration },
        items: [
          {
            value: "confirmed",
            text: declarationLabel,
            checked: values.declaration == "confirmed"
          }
        ]
      }) }}

      <p class="govuk-body">Date of declaration: {{ submissionDate }}</p>

      {{ govukButton({ text: "Submit notification" }) }}
    </form>
  {% endif %}
{% endblock %}

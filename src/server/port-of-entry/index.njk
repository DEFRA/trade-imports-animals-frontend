{% extends 'layouts/page.njk' %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block pageContent %}

  {{ govukBackLink({
    text: "Back",
    href: "/addresses"
  }) }}

  {{ appReferenceNumberCaption({ referenceNumber: referenceNumber }) }}
  {{ appHeading({ pageTitle: "Transport", heading: "Entry point and arrival at destination" }) }}

      <div class="govuk-body" data-testid="app-page-body">

        {% if errorList %}
          {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: errorList
          }) }}
        {% endif %}

        <form method="post" novalidate>
          <input type="hidden" name="crumb" value="{{ crumb }}" />

          {{ govukSelect({
            id: "portOfEntry",
            name: "portOfEntry",
            label: {
              text: "What is the port of entry into Great Britain?",
              classes: "govuk-label--m"
            },
            value: portOfEntry if portOfEntry,
            errorMessage: fieldErrors["portOfEntry"] if fieldErrors,
            items: [
              { value: "", text: "Select port of entry" },
              { text: "──────────", disabled: true },
              { value: "ABERDEEN", text: "ABERDEEN" },
              { value: "EAST MIDLANDS AIRPORT", text: "EAST MIDLANDS AIRPORT" },
              { value: "EDINBURGH", text: "EDINBURGH" }
            ]
          }) }}

          {{ govukDateInput({
            id: "arrivalDate",
            namePrefix: "arrivalDate",
            fieldset: {
              legend: {
                text: "When will the consignment arrive at its final destination?",
                classes: "govuk-fieldset__legend--m"
              }
            },
            hint: {
              text: "For example, 27 3 2026"
            },
            errorMessage: fieldErrors["arrivalDate-day"] or fieldErrors["arrivalDate-month"] or fieldErrors["arrivalDate-year"] if fieldErrors,
            items: [
              {
                label: "Day",
                id: "arrivalDate-day",
                name: "day",
                classes: "govuk-input--width-2",
                value: arrivalDate.day if arrivalDate
              },
              {
                label: "Month",
                id: "arrivalDate-month",
                name: "month",
                classes: "govuk-input--width-2",
                value: arrivalDate.month if arrivalDate
              },
              {
                label: "Year",
                id: "arrivalDate-year",
                name: "year",
                classes: "govuk-input--width-4",
                value: arrivalDate.year if arrivalDate
              }
            ]
          }) }}

          <div class="govuk-button-group">
            {{ govukButton({
              text: "Save and continue"
            }) }}
          </div>
        </form>

      </div>
{% endblock %}

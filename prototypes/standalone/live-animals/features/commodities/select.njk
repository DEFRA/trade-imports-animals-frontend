{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukSelect({
      id: "commoditySelection",
      name: "commoditySelection",
      label: { text: "Commodity", classes: "govuk-label--s" },
      hint: { text: "Search by common name, species or commodity code." },
      value: values.commoditySelection,
      errorMessage: errors.commoditySelection and { text: errors.commoditySelection },
      items: commodityItems
    }) }}

    {{ govukRadios({
      name: "typeSelection",
      fieldset: { legend: { text: "Type", classes: "govuk-fieldset__legend--s" } },
      hint: { text: "Where it applies, you can filter species by type." },
      items: typeOptions,
      errorMessage: errors.typeSelection and { text: errors.typeSelection }
    }) }}

    {{ govukCheckboxes({
      name: "speciesSelection",
      fieldset: { legend: { text: "Species", classes: "govuk-fieldset__legend--s" } },
      hint: { text: "Select all that apply." },
      items: speciesOptions
    }) }}

    {{ govukButton({ text: "Save and continue" }) }}
  </form>
{% endblock %}

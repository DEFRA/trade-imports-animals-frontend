{# Add-a-claim sub-page. Bespoke frame (graft 9): the page lives outside
   the Container tree (the Flow page's `addPage`), but its fields still
   arrive through the generic FieldViewItem projection. Context:
   { heading, buttonText ('Add claim'), fields, errorSummary?,
   errorSummaryTitle }. #}
{% extends layout %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "standalone/obligations-standalone-spike/templates/partials/fields.njk" import renderFields %}

{% block journeyContent %}
  {% include "standalone/obligations-standalone-spike/templates/partials/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ renderFields(fields) }}

    {{ govukButton({ text: buttonText }) }}
  </form>
{% endblock %}

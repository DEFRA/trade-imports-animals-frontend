{
  "name": "trade-imports-animals-frontend",
  "version": "0.0.0",
  "description": "CDP Frontend Template",
  "sideEffects": false,
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:frontend": "NODE_ENV=production webpack",
    "dev": "AWS_EMF_ENVIRONMENT=Local run-p build:frontend frontend:watch server:watch",
    "dev:debug": "AWS_EMF_ENVIRONMENT=Local run-p frontend:watch server:debug",
    "docker:dev": "npm run dev",
    "prototype": "FEATURES_PROTOTYPES_ENABLED=true AUTH_ENABLED=false npm run dev",
    "prototype:real": "LIVE_ANIMALS_MODE=real SESSION_CACHE_ENGINE=redis REDIS_HOST=127.0.0.1 npm run prototype",
    "prototype:start": "FEATURES_PROTOTYPES_ENABLED=true AUTH_ENABLED=false NODE_ENV=development node .",
    "prototype:real:start": "LIVE_ANIMALS_MODE=real SESSION_CACHE_ENGINE=redis REDIS_HOST=127.0.0.1 npm run prototype:start",
    "prototype:serve": "npm run build:frontend && npm run prototype:start",
    "prototype:reset": "node -e \"require('node:fs').writeFileSync('prototypes/shared/data/quotes.json','[]\\n')\"",
    "check:workspace-stack": "node prototypes/e2e/check-workspace-stack.js",
    "test:prototype": "npm run check:workspace-stack && npm run build:frontend && DEMO_SLOWMO=0 DEMO_PACE_MS=0 playwright test",
    "test:prototype:journeys": "npm run check:workspace-stack && npm run build:frontend && DEMO_SLOWMO=0 DEMO_PACE_MS=0 playwright test --project=prototype",
    "test:prototype:parity": "npm run check:workspace-stack && npm run build:frontend && playwright test --project=parity",
    "test:prototype:demo": "npm run check:workspace-stack && npm run build:frontend && DEMO_SLOWMO=600 DEMO_PACE_MS=1500 playwright test --project=prototype",
    "format": "prettier --write \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "frontend:watch": "NODE_ENV=development webpack --watch",
    "git:pre-commit-hook": "npm run format:check && npm run lint && npm test",
    "postinstall": "npm run setup:husky",
    "lint": "run-s lint:js lint:scss",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "pretest": "npm run build:frontend",
    "test": "TZ=UTC vitest run --coverage --exclude ./tests/**",
    "test:spike-a": "TZ=UTC vitest run prototypes/standalone/spike-a --no-coverage",
    "test:spike-b": "TZ=UTC vitest run prototypes/standalone/spike-b --no-coverage",
    "test:spike-c": "TZ=UTC vitest run prototypes/standalone/spike-c --no-coverage",
    "test:spike-d": "TZ=UTC vitest run prototypes/standalone/spike-d --no-coverage",
    "test:obligations-standalone-spike": "TZ=UTC vitest run prototypes/standalone/obligations-standalone-spike --no-coverage",
    "test:obligations-v2-spike": "TZ=UTC vitest run prototypes/standalone/obligations-v2-spike --no-coverage",
    "dump:obligations-v2-spike": "node prototypes/standalone/obligations-v2-spike/dump.js",
    "test:live-animals": "TZ=UTC vitest run prototypes/standalone/live-animals --no-coverage",
    "dump:live-animals": "node prototypes/standalone/live-animals/dump.js",
    "capture:live-animals": "node prototypes/standalone/live-animals/services/_capture/capture.js",
    "lighthouse": "lhci autorun",
    "test:watch": "TZ=UTC vitest",
    "security-audit": "npm audit --audit-level=high",
    "server:watch": "nodemon --inspect=0.0.0.0 --ext js,json,njk --legacy-watch ./src",
    "server:debug": "nodemon --inspect-brk=0.0.0.0 --ext js,json,njk --legacy-watch ./src",
    "prestart": "npm run build:frontend",
    "start": "NODE_ENV=production node --use-strict .",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@defra/cdp-auditing": "0.6.0",
    "@defra/cdp-metrics": "0.5.0",
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/bell": "^13.1.0",
    "@hapi/catbox-memory": "6.0.2",
    "@hapi/catbox-redis": "7.0.2",
    "@hapi/cookie": "^12.0.1",
    "@hapi/crumb": "^9.0.1",
    "@hapi/hapi": "21.4.8",
    "@hapi/inert": "7.1.1",
    "@hapi/jwt": "^3.2.3",
    "@hapi/scooter": "^8.0.0",
    "@hapi/validate": "^2.0.1",
    "@hapi/vision": "7.0.3",
    "@hapi/wreck": "^18.1.0",
    "@hapi/yar": "11.0.3",
    "blankie": "5.0.0",
    "convict": "^6.2.5",
    "convict-format-with-validator": "6.2.0",
    "cssnano": "7.1.4",
    "cssnano-preset-default": "7.0.12",
    "date-fns": "4.1.0",
    "global-agent": "4.1.3",
    "govuk-frontend": "^6.3.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "ioredis": "5.10.1",
    "lodash": "4.18.1",
    "node-fetch": "3.3.2",
    "nunjucks": "3.2.4",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "semver": "7.7.4",
    "undici": "8.5.0"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.2",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.0",
    "@vitest/coverage-v8": "4.1.3",
    "accessible-autocomplete": "3.0.1",
    "autoprefixer": "10.4.27",
    "babel-loader": "10.1.1",
    "cheerio": "1.2.0",
    "clean-webpack-plugin": "4.0.0",
    "copy-webpack-plugin": "14.0.0",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "neostandard": "0.12.2",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "postcss-load-config": "6.0.1",
    "postcss-loader": "8.2.1",
    "prettier": "3.8.1",
    "puppeteer": "25.0.4",
    "sass-embedded": "1.99.0",
    "sass-loader": "16.0.7",
    "source-map-loader": "5.0.0",
    "stylelint": "16.26.1",
    "stylelint-config-gds": "2.0.0",
    "terser-webpack-plugin": "5.4.0",
    "testcontainers": "12.0.4",
    "vitest": "4.1.3",
    "vitest-fetch-mock": "0.4.5",
    "webpack": "5.105.4",
    "webpack-assets-manifest": "6.5.1",
    "webpack-cli": "7.0.2"
  },
  "overrides": {
    "tmp": "0.2.7",
    "uuid": "11.1.1",
    "serialize-javascript": "7.0.5",
    "flatted": "^3.4.0",
    "vite": "6.4.3",
    "esbuild": "0.28.1",
    "lighthouse": {
      "ws": "7.5.11"
    },
    "puppeteer-core": {
      "ws": "8.21.0"
    }
  }
}

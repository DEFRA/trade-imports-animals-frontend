{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% block content %}
  {{ appReferenceNumberCaption({ referenceNumber: referenceNumber }) }}

  {{ govukBackLink({
    text: "Back",
    href: "/accompanying-documents"
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="app-page-body">

        <span class="govuk-caption-l">{{ heading }}</span>
        <h1 class="govuk-heading-l">{{ heading }}</h1>

        <form method="post" novalidate>
          <input type="hidden" name="crumb" value="{{ crumb }}" />

          <div class="govuk-fieldset">
            <div class="govuk-form-group">
              <fieldset class="govuk-fieldset">
                <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                  <h2 class="govuk-fieldset__heading">Consigner or exporter</h2>
                </legend>
                <div id="consignor-hint" class="govuk-hint">
                  This is the sender of the consignment.
                </div>
                <p class="govuk-body">
                  <a href="#" class="govuk-link govuk-link--no-visited-state" id="addConsignorOrExporter">Add a consignor or exporter</a>
                </p>
              </fieldset>
            </div>
            <div class="govuk-form-group">
              <fieldset class="govuk-fieldset">
                <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                  <h2 class="govuk-fieldset__heading">Consignee</h2>
                </legend>
                <div id="consignee-hint" class="govuk-hint">
                  This is the receiver or buyer of the consignment being shipped or transported.
                </div>
                <p class="govuk-body">
                  <a href="#" class="govuk-link govuk-link--no-visited-state" id="addConsignee">Add a consignee</a>
                </p>
              </fieldset>
            </div>
            <div class="govuk-form-group">
              <fieldset class="govuk-fieldset">
                <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                  <h2 class="govuk-fieldset__heading">Importer</h2>
                </legend>
                <div id="importer-hint" class="govuk-hint">
                  This is usually the same as the consignee. You can select a different person if needed.
                </div>
                <p class="govuk-body">
                  <a href="#" class="govuk-link govuk-link--no-visited-state" id="addImporter">Add an importer</a>
                </p>
              </fieldset>
            </div>
            <div class="govuk-form-group">
              <fieldset class="govuk-fieldset">
                <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                  <h2 class="govuk-fieldset__heading">Place of destination</h2>
                </legend>
                <div id="place-of-destination-hint" class="govuk-hint">
                  This is where the animals will be unloaded and accommodated for at least 48 hours. If a health certificate is required, it will show this address.
                </div>
                <div class="govuk-warning-text">
                  <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                  <strong class="govuk-warning-text__text">
                    <span class="govuk-visually-hidden">Warning</span>
                    Providing a false address is an act of fraud.
                  </strong>
                </div>
                <p class="govuk-body">
                  <a href="#" class="govuk-link govuk-link--no-visited-state" id="addPlaceOfDestination">Add a place of destination</a>
                </p>
              </fieldset>
            </div>
          </div>

          <button type="submit" class="govuk-button" data-module="govuk-button">
            Save and continue
          </button>

        </form>
      </div>
    </div>
  </div>
{% endblock %}

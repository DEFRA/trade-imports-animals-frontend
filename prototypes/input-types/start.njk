{% extends "input-types/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block journeyContent %}
  <h1 class="govuk-heading-xl">Input types reference</h1>

  <p class="govuk-body">
    A worked example of the GOV.UK Design System form inputs — how each one looks,
    is labelled and hinted. The last pages show conditional reveals, autocomplete,
    file upload and an error state.
  </p>

  <form method="post" action="/prototype/input-types/start" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />
    {{ govukButton({ text: "Start now", isStartButton: true }) }}
  </form>
{% endblock %}

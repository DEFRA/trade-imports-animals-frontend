{# Claims manage-list. Bespoke frame (graft 9): the add/remove/continue
   actions bypass the generic presents projection because the model has
   no list-management vocabulary (TOOL-14) — rows arrive as govuk
   summary-list rows ('Claim N' keys, 'Remove claim N' accessible
   names). Copy passes through from the Flow page's `listCopy`. #}
{% extends layout %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block journeyContent %}
  <h1 class="govuk-heading-l">{{ heading }}</h1>

  {% if rows.length %}
    {{ govukSummaryList({ rows: rows }) }}
  {% else %}
    <p class="govuk-body">{{ listCopy.emptyText }}</p>
  {% endif %}

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukButton({
      text: listCopy.addAnotherButtonText if rows.length else listCopy.addButtonText,
      classes: "govuk-button--secondary",
      name: "action",
      value: "add"
    }) }}

    <div class="govuk-button-group">
      {{ govukButton({ text: listCopy.continueButtonText, name: "action", value: "continue" }) }}
    </div>
  </form>
{% endblock %}

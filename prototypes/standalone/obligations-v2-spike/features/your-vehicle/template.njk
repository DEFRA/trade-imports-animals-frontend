{% extends "standalone/obligations-v2-spike/shared/layout.njk" %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/file-upload/macro.njk" import govukFileUpload %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block journeyContent %}
  {% include "standalone/obligations-v2-spike/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukInput({
      id: "registration", name: "registration",
      label: { text: "Registration number" },
      classes: "govuk-input--width-10",
      value: values.registration,
      errorMessage: errors.registration and { text: errors.registration }
    }) }}

    {{ govukInput({
      id: "make", name: "make",
      label: { text: "Make" },
      hint: { text: "Start typing to see suggestions" },
      value: values.make,
      attributes: { list: "make-suggestions" }
    }) }}
    <datalist id="make-suggestions">
      {% for make in makes %}<option value="{{ make }}"></option>{% endfor %}
    </datalist>

    {{ govukInput({ id: "model", name: "model", label: { text: "Model" }, value: values.model }) }}

    {{ govukInput({
      id: "year", name: "year",
      label: { text: "Year of manufacture" },
      classes: "govuk-input--width-5",
      inputmode: "numeric",
      value: values.year,
      errorMessage: errors.year and { text: errors.year }
    }) }}

    {{ govukInput({
      id: "estimatedValue", name: "estimatedValue",
      label: { text: "Estimated value" },
      classes: "govuk-input--width-5",
      inputmode: "numeric",
      prefix: { text: "£" },
      value: values.estimatedValue,
      errorMessage: errors.estimatedValue and { text: errors.estimatedValue }
    }) }}

    {{ govukFileUpload({
      id: "vehiclePhoto", name: "vehiclePhoto",
      label: { text: "Upload a photo of your vehicle (optional)" },
      hint: { text: "This is a prototype, so the file is not saved" }
    }) }}

    {{ govukButton({ text: "Save and continue" }) }}
  </form>
{% endblock %}

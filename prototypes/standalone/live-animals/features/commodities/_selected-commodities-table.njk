{% from "govuk/components/table/macro.njk" import govukTable %}

{# One row per selected commodity: code, common name, Remove (design 01-14). #}
{% macro selectedCommoditiesTable(groups) %}
  {% set rows = [] %}
  {% for group in groups %}
    {% set removeCell %}
      <a class="govuk-link" href="{{ group.removeHref }}">Remove<span class="govuk-visually-hidden"> {{ group.name }}</span></a>
    {% endset %}
    {% set ignored = rows.push([
      { text: group.code },
      { text: group.name },
      { html: removeCell, classes: "govuk-!-text-align-right" }
    ]) %}
  {% endfor %}
  {{ govukTable({
    caption: "Selected commodities",
    captionClasses: "govuk-table__caption--m",
    head: [
      { text: "Commodity code" },
      { text: "Common name" },
      { html: '<span class="govuk-visually-hidden">Actions</span>' }
    ],
    rows: rows
  }) }}
{% endmacro %}

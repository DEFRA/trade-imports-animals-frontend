{% extends "input-types/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/file-upload/macro.njk" import govukFileUpload %}

{% block journeyContent %}
  <h1 class="govuk-heading-l">Advanced inputs</h1>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {% set otherHtml %}
      {{ govukInput({
        label: { text: "How did you hear about us?" },
        id: "contactOther",
        name: "contactOther",
        value: quote.contactOther
      }) }}
    {% endset %}

    {# Conditional reveal: choosing "Other" reveals a follow-up input #}
    {{ govukRadios({
      name: "heardFrom",
      fieldset: {
        legend: { text: "How did you hear about us?", classes: "govuk-fieldset__legend--m" }
      },
      items: [
        { value: "search", text: "Search engine", checked: quote.heardFrom == "search" },
        { value: "friend", text: "Friend or family", checked: quote.heardFrom == "friend" },
        { value: "other", text: "Other", checked: quote.heardFrom == "other", conditional: { html: otherHtml } }
      ]
    }) }}

    {# Autocomplete via a native datalist — no extra JS dependency #}
    {{ govukInput({
      label: { text: "Make of vehicle" },
      hint: { text: "Start typing to see suggestions" },
      id: "vehicleMake",
      name: "vehicleMake",
      value: quote.vehicleMake,
      attributes: { list: "vehicleMakes", autocomplete: "off" }
    }) }}
    <datalist id="vehicleMakes">
      <option value="Audi"></option>
      <option value="BMW"></option>
      <option value="Ford"></option>
      <option value="Nissan"></option>
      <option value="Toyota"></option>
      <option value="Volkswagen"></option>
    </datalist>

    {{ govukFileUpload({
      id: "document",
      name: "document",
      label: { text: "Upload a supporting document" },
      hint: { text: "This is a prototype, so the file is not saved" }
    }) }}

    {{ govukButton({ text: "Continue" }) }}
  </form>
{% endblock %}

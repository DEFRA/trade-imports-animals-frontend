{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
  {{ appHeading({
    text: heading
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="app-page-body">
        {% if errorList %}
          {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: errorList
          }) }}
        {% endif %}

        <form method="post" action="/start-journey">
          <input type="hidden" name="crumb" value="{{ crumb }}"/>
          <div class="govuk-button-group">
            {{ govukButton({
              text: "Create an import notification"
            }) }}
          </div>
        </form>

        <hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible">

        <div class="govuk-grid-row dashboard-results-header">
          <div class="govuk-grid-column-one-half">
            {% if not errorList %}
              <label class="govuk-label govuk-label--s">{{ notifications | length }} Results</label>
            {% endif %}
          </div>
          <div class="govuk-grid-column-one-half govuk-!-text-align-right">
            <form method="get" action="/" class="dashboard-sort" data-module="dashboard-sort" data-testid="dashboard-sort-form">
              {{ govukSelect({
                id: "sort",
                name: "sort",
                classes: "govuk-!-display-inline-block",
                label: {
                  text: "Sort by:",
                  classes: "govuk-label--s govuk-!-display-inline-block govuk-!-margin-right-2"
                },
                value: sort,
                items: sortOptions
              }) }}
              <noscript>
                {{ govukButton({
                  text: "Sort",
                  classes: "govuk-button--secondary"
                }) }}
              </noscript>
            </form>
          </div>
        </div>

        {% if not errorList %}
          {% for notification in notifications %}
              <div class="govuk-summary-card notification-list">
                <div class="govuk-summary-card__title-wrapper">
                  <h2 class="govuk-summary-card__title">
                    {{ notification.referenceNumber }}
                  </h2>
                  <ul class="govuk-summary-card__actions">
                    <li class="govuk-summary-card__action">
                      <a class="govuk-link" href="/notification-view/{{ notification.referenceNumber }}">
                        View<span class="govuk-visually-hidden"> {{ notification.referenceNumber }}</span>
                      </a>
                    </li>
                  </ul>
                </div>
                <div class="govuk-summary-card__content">
                  <div class="notification-list__grid-row">
                    <div class="notification-list__grid-column-30">
                      <dt class="notification-list__heading">Commodity</dt>
                      <dd class="notification-list__value">{{ notification.commodity.name }}</dd>
                    </div>
                    <div class="notification-list__grid-column-30">
                      <dt class="notification-list__heading">Origin</dt>
                      <dd class="notification-list__value">{{ notification.origin.countryCode }}</dd>
                    </div>
                    <div class="notification-list__grid-column-30">
                      <dt class="notification-list__heading">Arrival at destination</dt>
                      <dd class="notification-list__value">{{ notification.arrivalAtDestination }}</dd>
                    </div>
                  </div>
                  <div class="notification-list__grid-row">
                    <div class="notification-list__grid-column-30">
                      <dt class="notification-list__heading">Consignee</dt>
                      {# TODO: Consignee value not defined — out of scope for EUDPA-69 #}
                      <dd class="notification-list__value"></dd>
                    </div>
                    <div class="notification-list__grid-column-30">
                      <dt class="notification-list__heading">Consignor</dt>
                      <dd class="notification-list__value">{{ notification.consignor.name }}</dd>
                    </div>
                    <div class="notification-list__grid-column-30">
                      <dt class="notification-list__heading">Status</dt>
                      <dd class="notification-list__value">
                        <strong class="govuk-tag {{ 'govuk-tag--blue' if notification.status == 'SUBMITTED' else 'govuk-tag--grey' }}">
                          {{ notification.status | title }}
                        </strong>
                      </dd>
                    </div>
                  </div>
                  <div class="notification-list__grid-row">
                    <div class="notification-list__grid-column-full">
                      Date created: {{ notification.dateCreated }}
                    </div>
                  </div>
                </div>
              </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>

{% endblock %}

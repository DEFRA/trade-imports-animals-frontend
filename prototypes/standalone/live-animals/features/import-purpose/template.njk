{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "standalone/live-animals/shared/save-actions.njk" import saveActions %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukRadios({
      name: "purposeInInternalMarket",
      fieldset: {
        legend: {
          text: "Purpose in the internal market",
          isPageHeading: true,
          classes: "govuk-fieldset__legend--l"
        }
      },
      errorMessage: errors.purposeInInternalMarket and { text: errors.purposeInInternalMarket },
      items: purposeOptions
    }) }}

    {{ saveActions(hubHref) }}
  </form>
{% endblock %}

{% extends 'layouts/page.njk' %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
  {{ appReferenceNumberCaption({ referenceNumber: referenceNumber }) }}

  {{ govukBackLink({
    text: "Back",
    href: "/transporter"
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="app-page-body">

        {% if errorList %}
          {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: errorList
          }) }}
        {% endif %}

        <h1 class="govuk-heading-l">{{ pageTitle }}</h1>

        <p class="govuk-body">Date of declaration: <strong>{{ submissionDate }}</strong></p>

        <form method="post" novalidate>
          <input type="hidden" name="crumb" value="{{ crumb }}" />

          {{ govukCheckboxes({
            name: "declaration",
            errorMessage: fieldErrors["declaration"] if fieldErrors,
            items: [
              {
                value: "confirmed",
                text: "I confirm that the information I have provided is true and correct and I am authorised to submit this notification"
              }
            ]
          }) }}

          <div class="govuk-button-group">
            {{ govukButton({
              text: "Confirm and submit"
            }) }}
          </div>
        </form>

      </div>
    </div>
  </div>

{% endblock %}

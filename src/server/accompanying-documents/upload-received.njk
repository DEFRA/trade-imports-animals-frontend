{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}

{% block head %}
  {{ super() }}
  {% if scanStatus === 'PENDING' and not timedOut %}
    <meta http-equiv="refresh" content="3; url=?attempt={{ nextAttempt }}">
  {% endif %}
{% endblock %}

{% block content %}

  {% if scanStatus === 'COMPLETE' %}

    {{ govukPanel({
      titleText: "Document uploaded successfully"
    }) }}

    <p class="govuk-body">Your document has been checked and is safe to use.</p>

    {{ govukButton({
      text: "Continue",
      href: "/"
    }) }}

  {% elif scanStatus === 'REJECTED' %}

    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: [
        { text: "The selected file contains a virus" }
      ]
    }) }}

    <h1 class="govuk-heading-l">{{ heading }}</h1>

    <p class="govuk-body">The selected file contains a virus and could not be uploaded.</p>
    <p class="govuk-body">Remove the file and try again with a different file.</p>

    {{ govukButton({
      text: "Try again",
      href: "/accompanying-documents"
    }) }}

  {% elif timedOut %}

    {{ appHeading({ text: heading }) }}

    <p class="govuk-body">We are still checking your document for viruses.</p>
    <p class="govuk-body">
      <a href="?attempt={{ nextAttempt }}" class="govuk-link">Refresh to check status</a>
    </p>

  {% else %}

    {{ appHeading({ text: heading }) }}

    <p class="govuk-body">This usually takes a few seconds.</p>
    <p class="govuk-body">
      <a href="?attempt={{ nextAttempt }}" class="govuk-link">Refresh to check status</a>
    </p>

  {% endif %}

{% endblock %}

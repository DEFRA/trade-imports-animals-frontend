{# Adapted from prototype-layouts branch (obligations-standalone-spike/templates/page.njk).

   The generic form-page template. Every flow-driven Page renders here
   from a pageViewModel context ({ heading, buttonText, fields, backLink })
   plus optional errorSummary. Zero hardcoded copy. #}

{% extends "layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "partials/fields.njk" import renderFields %}

{% block journeyContent %}
  {% include "partials/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  {% if lead %}
    <p class="govuk-body">{{ lead }}</p>
  {% endif %}

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ renderFields(fields) }}

    {{ govukButton({ text: buttonText }) }}
  </form>
{% endblock %}

{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <h2 class="govuk-heading-m">I am the contact for the authorities and located in the UK.</h2>

  <h2 class="govuk-heading-m">I confirm I am responsible for this consignment until it has cleared border control checks or reached the place of destination.</h2>

  <h2 class="govuk-heading-m">I confirm that I am accountable for:</h2>

  <ul class="govuk-list govuk-list--bullet">
    <li>payments for border control checks</li>
    <li>re-dispatch of the consignment</li>
    <li>quarantine or isolation of the animals</li>
    <li>the costs of destruction and disposal</li>
  </ul>

  <p class="govuk-body">I am authorised as being accountable for these things if raising notifications on behalf of a third party.</p>

  <p class="govuk-body">I can legally act on behalf of a third party in relation to the conditions of this declaration.</p>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukCheckboxes({
      name: "declaration",
      errorMessage: errors.declaration and { text: errors.declaration },
      items: [
        {
          value: "confirmed",
          text: declarationLabel,
          checked: values.declaration == "confirmed"
        }
      ]
    }) }}

    <p class="govuk-body">Date of declaration: {{ submissionDate }}</p>

    {{ govukButton({ text: "Continue" }) }}
  </form>
{% endblock %}

{% extends 'layouts/page.njk' %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block pageContent %}

  {{ govukBackLink({
    text: "Back",
    href: "/addresses"
  }) }}

  {{ appReferenceNumberCaption({ referenceNumber: referenceNumber }) }}
  {{ appHeading({ heading: "Add the County Parish Holding number (CPH)" }) }}

      <div class="govuk-body" data-testid="app-page-body">

        {% if errorList %}
          {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: errorList
          }) }}
        {% endif %}

        <form method="post" novalidate>
          <input type="hidden" name="crumb" value="{{ crumb }}" />

          {{ govukInput({
            label: {
              text: "CPH number"
            },
            id: "cphNumber",
            name: "cphNumber",
            classes: "govuk-!-width-two-thirds",
            value: cphNumber if cphNumber,
            spellcheck: false,
            attributes: {
              maxlength: "11"
            },
            errorMessage: fieldErrors.cphNumber if fieldErrors
          }) }}

          <div class="govuk-button-group">
            {{ govukButton({
              text: "Save and continue"
            }) }}
          </div>
        </form>

      </div>
{% endblock %}

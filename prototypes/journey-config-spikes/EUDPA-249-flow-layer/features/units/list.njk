{# Units index for a single commodity line — depth-2. One summary
   block per unit with per-row Change links (into that unit's
   specific page) and a per-unit Delete form. Add mints a new unit
   and redirects into its first per-unit page (see
   linesUnitsAddController). #}

{% extends "shared/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block journeyContent %}
  <h1 class="govuk-heading-l">{{ heading }}</h1>

  {% if lead %}<p class="govuk-body">{{ lead }}</p>{% endif %}

  {% if units and units.length %}
    {% for unit in units %}
      <h2 class="govuk-heading-m govuk-!-margin-top-6">{{ unit.title }}</h2>
      {{ govukSummaryList({ rows: unit.rows }) }}
      <form method="post" action="{{ unit.deleteHref }}" novalidate class="govuk-!-margin-bottom-6">
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        {{ govukButton({
          text: unit.deleteButtonText,
          classes: "govuk-button--warning govuk-button--secondary",
          attributes: { "aria-label": unit.deleteVisuallyHiddenText }
        }) }}
      </form>
    {% endfor %}
  {% else %}
    <p class="govuk-body">{{ emptyText }}</p>
  {% endif %}

  <form method="post" action="{{ addHref }}" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />
    {{ govukButton({ text: addButtonText, classes: "govuk-button--secondary" }) }}
  </form>

  {% if backLink %}
    <p class="govuk-body">
      <a class="govuk-link" href="{{ backLink }}">{{ backLinkText }}</a>
    </p>
  {% endif %}
{% endblock %}

{% extends "standalone/live-animals/shared/layout.njk" %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block journeyContent %}
  {% include "standalone/live-animals/shared/error-summary.njk" %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    {{ govukTextarea({
      id: "modDescription", name: "modDescription",
      label: { text: "Describe the modifications" },
      hint: { text: "For example, alloy wheels or a remapped engine" },
      value: value,
      errorMessage: errors.modDescription and { text: errors.modDescription }
    }) }}

    {{ govukButton({ text: "Save and continue" }) }}
  </form>
{% endblock %}
